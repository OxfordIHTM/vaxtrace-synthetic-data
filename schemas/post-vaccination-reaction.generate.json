  "$defs": {
    "grade": {
      "type": "integer",
      "enum": [
        1,
        2,
        3
      ],
      "description": "Severity 1 (mild) to 3 (severe), per the reaction-specific legend in the source form."
    },
    "management": {
      "type": "object",
      "description": "Present only when this reaction was managed in this setting.",
      "properties": {
        "recorded": {
          "type": "boolean",
          "description": "Whether management occurred in this setting."
        },
        "grade": {
          "$ref": "#/$defs/grade"
        },
        "adrenaline": {
          "type": "boolean",
          "description": "Adrenaline administered (centre only)."
        },
        "other": {
          "type": "string",
          "description": "Other management/treatment given."
        }
      },
      "required": [
        "recorded"
      ]
    },
    "reaction": {
      "type": "object",
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "local",
            "systemic"
          ]
        },
        "reaction_type": {
          "type": "string",
          "enum": [
            "Pain at injection site",
            "Swelling/induration at injection site",
            "Redness/bruising at injection site",
            "Localised rash",
            "Rash/hives",
            "Headache",
            "Cyanosis/pallor",
            "Difficulty breathing",
            "Nausea/vomiting",
            "Diarrhoea",
            "Poor appetite/loss of appetite",
            "Fatigue/malaise",
            "Fever",
            "Drowsiness",
