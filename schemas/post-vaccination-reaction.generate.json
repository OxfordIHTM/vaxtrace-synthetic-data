{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/OxfordIHTM/vaxtrace-synthetic-data/schemas/post-vaccination-reaction.generate.json",
  "title": "Post-vaccination reaction record (synthetic generation)",
  "description": "One filled-in post-vaccination reaction monitoring form. Generate plausible, internally consistent values: detail fields (grades, dates, management) should be present ONLY for reactions where occurred = true.",
  "type": "object",
  "properties": {
    "client_id": {
      "type": "string",
      "pattern": "^[0-9]{10}$",
      "description": "Unique identifier for the client who received the vaccine. Ten numeric digits, e.g. 1234567890. Generate a new identifier at every generation turn."
    },
    "vaccination_date": {
      "type": "string",
      "format": "date",
      "description": "The date the vaccine was administered (vaccination date). Format: YYYY-MM-DD."
    },
    "vaccines_given_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4,
      "description": "Number of vaccines given at this vaccination event; must equal vaccines.length."
    },
    "vaccines": {
      "type": "array",
      "minItems": 1,
      "description": "Vaccines administered at this vaccination event.",
      "items": {
        "type": "object",
        "properties": {
          "vaccine_trade_name": {
            "type": "string",
            "description": "Commercial vaccine name."
          },
          "antigens": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "One or more antigens in this product."
          },
          "lot_number": {
            "type": "string",
            "pattern": "^[0-9]{3}-[0-9]{2}-[0-9]{2}$",
            "description": "Manufacturer lot/batch number, exact format [0-9]{3}-[0-9]{2}-[0-9]{2}, e.g. 123-01-01."
          },
          "expiry_date": {
            "type": "string",
            "format": "date",
            "description": "Product expiry, on or after the vaccination date (top-level `vaccination_date`)."
          },
          "injection_site": {
            "type": "string",
            "description": "Anatomical site, or 'N/A'."
          }
        },
        "required": [
          "vaccine_trade_name",
          "antigens",
          "lot_number",
          "expiry_date",
          "injection_site"
        ]
      }
    },
    "reactions": {
      "type": "array",
      "minItems": 17,
      "maxItems": 17,
      "description": "Emit exactly one entry per reaction on the checklist -- all 17, in the fixed order below. Each slot's reaction_type and category are predetermined; you supply occurred and, where occurred is true, the detail fields.",
      "prefixItems": [
        {
          "type": "object",
          "properties": {
            "category": {
              "const": "local"
            },
            "reaction_type": {
              "const": "Pain at injection site"
            },
            "occurred": {
              "type": "boolean",
              "description": "The Yes/No question for this reaction."
            },
            "managed_at_centre": {
              "$ref": "#/$defs/management"
            },
            "managed_at_home": {
              "$ref": "#/$defs/management"
            },
            "treatment_start_date": {
              "type": "string",
              "format": "date"
            },
            "treatment_end_date": {
              "type": "string",
              "format": "date",
              "description": "On or after treatment_start_date."
            },
            "symptom_start_datetime": {
              "type": "string",
              "format": "date-time",
              "description": "Symptom onset (single date-time)."
            },
            "symptom_end_datetime": {
              "type": "string",
              "format": "date-time",
              "description": "Symptom resolution; on or after onset."
            }
          },
          "required": [
            "category",
            "reaction_type",
            "occurred"
          ]
        },
        {
